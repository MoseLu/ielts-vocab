# Load this after backend/.env when starting the split microservices locally.
# The init-local-postgres-microservices.ps1 script can generate a real version
# of this file with created databases and service passwords.

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_SSLMODE=disable
DB_BACKUP_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=56379
REDIS_KEY_PREFIX=ielts-vocab-local
GATEWAY_BFF_REDIS_DB=0
IDENTITY_SERVICE_REDIS_DB=1
LEARNING_CORE_SERVICE_REDIS_DB=2
CATALOG_CONTENT_SERVICE_REDIS_DB=3
AI_EXECUTION_SERVICE_REDIS_DB=4
NOTES_SERVICE_REDIS_DB=5
TTS_MEDIA_SERVICE_REDIS_DB=6
ASR_SERVICE_REDIS_DB=7
ADMIN_OPS_SERVICE_REDIS_DB=8
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5679
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_DOMAIN_EXCHANGE=ielts-vocab.domain

IDENTITY_SERVICE_DATABASE_URL=postgresql://ielts_identity_service:replace_me@127.0.0.1:5432/ielts_identity_service?sslmode=disable
LEARNING_CORE_SERVICE_DATABASE_URL=postgresql://ielts_learning_core_service:replace_me@127.0.0.1:5432/ielts_learning_core_service?sslmode=disable
CATALOG_CONTENT_SERVICE_DATABASE_URL=postgresql://ielts_catalog_content_service:replace_me@127.0.0.1:5432/ielts_catalog_content_service?sslmode=disable
AI_EXECUTION_SERVICE_DATABASE_URL=postgresql://ielts_ai_execution_service:replace_me@127.0.0.1:5432/ielts_ai_execution_service?sslmode=disable
NOTES_SERVICE_DATABASE_URL=postgresql://ielts_notes_service:replace_me@127.0.0.1:5432/ielts_notes_service?sslmode=disable
TTS_MEDIA_SERVICE_DATABASE_URL=postgresql://ielts_tts_media_service:replace_me@127.0.0.1:5432/ielts_tts_media_service?sslmode=disable
ASR_SERVICE_DATABASE_URL=postgresql://ielts_asr_service:replace_me@127.0.0.1:5432/ielts_asr_service?sslmode=disable
ADMIN_OPS_SERVICE_DATABASE_URL=postgresql://ielts_admin_ops_service:replace_me@127.0.0.1:5432/ielts_admin_ops_service?sslmode=disable
